# =========================================
# Database
# =========================================
# For local development with SQLite (default, easy):
DATABASE_URL="file:./dev.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/syndicate?schema=public"

# =========================================
# Authentication (NextAuth / Auth.js v5)
# =========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="please-change-me-in-production-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# =========================================
# Application
# =========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="نقابة المختبرات والمعدات الطبية"
NEXT_PUBLIC_SITE_NAME_EN="Yemen Medical Labs & Equipment Syndicate"
NEXT_PUBLIC_SITE_COUNTRY="اليمن"

# =========================================
# File uploads (local by default)
# =========================================
UPLOAD_DRIVER="local" # local | s3
UPLOAD_LOCAL_DIR="public/uploads"
MAX_UPLOAD_MB="10"

# S3-compatible storage (optional, future)
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# =========================================
# Email (optional - logs to console if unset)
# =========================================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@syndicate.local"

# =========================================
# Payment (future - placeholder)
# =========================================
PAYMENT_DRIVER="none" # none | stripe | paymob
PAYMENT_PUBLIC_KEY=""
PAYMENT_SECRET_KEY=""

# =========================================
# Seed credentials (read by prisma/seed.ts)
# =========================================
SEED_ADMIN_EMAIL="admin@syndicate.local"
SEED_ADMIN_PASSWORD="Admin@12345"
SEED_DOCTOR_EMAIL="doctor@syndicate.local"
SEED_DOCTOR_PASSWORD="Doctor@12345"
